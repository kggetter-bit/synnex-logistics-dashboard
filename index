<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SYNNEX Logistics Intelligence Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.31.0/dist/tabler-icons.min.css">
<style>
:root{
  --navy:#0B1F4B;--navy2:#15336B;--navy3:#1E4080;
  --gold:#B8882A;--gold2:#D4A843;--gold3:#F5E8C8;--gold4:rgba(184,136,42,0.22);
  --white:#FFFFFF;--off:#F8F7F4;--surf:#F2F0EB;
  --td:#0B1F4B;--tm:#3D5075;--tmu:#7A8BAD;
  --bdr:#E2DDD5;--bdr2:#C8C2B8;
  --green:#0F6E56;--green2:rgba(15,110,86,0.1);
  --red:#993C1D;--red2:rgba(153,60,29,0.1);
  --amber:#854F0B;--amber2:rgba(133,79,11,0.1);
  --blue:#185FA5;--blue2:rgba(24,95,165,0.1);
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{font-family:'DM Sans',sans-serif;background:#EBE8E2;color:var(--td);min-height:100vh}
.shell{max-width:1300px;margin:0 auto;padding:20px}

.topbar{background:var(--navy);border-radius:14px 14px 0 0;padding:0 28px;display:flex;align-items:stretch;justify-content:space-between;box-shadow:0 4px 20px rgba(11,31,75,0.15)}
.brand{display:flex;align-items:center;gap:12px;padding:15px 0}
.brand-ico{width:36px;height:36px;background:var(--gold2);border-radius:9px;display:flex;align-items:center;justify-content:center}
.brand-ico i{font-size:18px;color:var(--navy)}
.brand-name{font-family:'Playfair Display',serif;font-size:18px;color:var(--white)}
.brand-name span{color:var(--gold2)}
.brand-sub{font-size:10px;color:rgba(255,255,255,0.35);letter-spacing:.12em;text-transform:uppercase;margin-top:2px}
.top-r{display:flex;align-items:center;gap:7px}
.top-chip{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:6px;padding:5px 12px;font-size:11px;color:rgba(255,255,255,.65);white-space:nowrap}
.top-chip.live{background:rgba(184,136,42,0.18);border-color:var(--gold4);color:var(--gold2)}
.wh-chips{display:flex;gap:5px}
.wh-chip{padding:3px 9px;border-radius:10px;font-size:10px;font-weight:500}
.gold-bar{height:3px;background:linear-gradient(90deg,var(--navy),var(--gold2) 40%,var(--gold) 60%,var(--navy))}
.nav{background:var(--white);border-bottom:1px solid var(--bdr);padding:0 28px;display:flex;gap:0;overflow-x:auto}
.nav::-webkit-scrollbar{height:0}
.nb{padding:13px 16px;font-size:12px;font-weight:500;letter-spacing:.04em;color:var(--tmu);cursor:pointer;border:none;border-bottom:2px solid transparent;white-space:nowrap;display:inline-flex;align-items:center;gap:6px;background:none;font-family:'DM Sans',sans-serif;transition:color .15s}
.nb.active{color:var(--navy);border-bottom-color:var(--gold2)}
.nb:hover:not(.active){color:var(--navy2)}
.nb i{font-size:14px}
.nb-cnt{background:var(--gold3);color:var(--gold);border-radius:10px;padding:1px 6px;font-size:10px;margin-left:2px;display:none}
.body{background:var(--white);padding:24px 28px;min-height:520px;border-radius:0 0 14px 14px;border:1px solid var(--bdr);border-top:none}
.sec{display:none}.sec.active{display:block}

.kpi5{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:12px;margin-bottom:18px}
.kpi4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin-bottom:18px}
.kpi{background:var(--white);border:1px solid var(--bdr);border-radius:12px;padding:16px 14px;position:relative;overflow:hidden;transition:box-shadow .2s}
.kpi:hover{box-shadow:0 4px 16px rgba(11,31,75,0.07)}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:2.5px;background:var(--gold2)}
.kpi.hl::before{background:linear-gradient(90deg,var(--gold2),var(--gold))}
.kpi-lbl{font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--tmu);margin-bottom:8px}
.kpi-val{font-family:'Playfair Display',serif;font-size:22px;color:var(--navy);line-height:1}
.kpi-sub{font-size:11px;color:var(--tmu);margin-top:6px;display:flex;align-items:center;gap:4px;flex-wrap:wrap}
.up{color:var(--green);font-weight:500}.dn{color:var(--red);font-weight:500}
.kpi-ico{position:absolute;top:14px;right:12px;width:30px;height:30px;background:var(--off);border-radius:7px;display:flex;align-items:center;justify-content:center}
.kpi-ico i{font-size:16px;color:var(--gold)}

.g2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:16px}
.panel{background:var(--white);border:1px solid var(--bdr);border-radius:12px;padding:18px 20px}
.ph{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.pt{font-size:11px;font-weight:500;letter-spacing:.06em;text-transform:uppercase;color:var(--tm);display:flex;align-items:center;gap:7px}
.pt i{color:var(--gold2);font-size:14px}
.ptag{font-size:10px;background:var(--gold3);color:var(--gold);border-radius:4px;padding:2px 8px;font-weight:500}
.ptag.gr{background:var(--green2);color:var(--green)}
.ptag.bl{background:var(--blue2);color:var(--blue)}
.ptag.rd{background:var(--red2);color:var(--red)}

.br{display:flex;align-items:center;gap:10px;margin-bottom:9px}
.bl{font-size:11px;color:var(--tmu);width:54px;text-align:right;flex-shrink:0}
.bt{flex:1;height:7px;background:var(--surf);border-radius:4px;overflow:hidden}
.bf{height:100%;border-radius:4px;transition:width .4s ease}
.bf.navy{background:var(--navy)}.bf.gold{background:var(--gold2)}.bf.blue{background:var(--blue)}.bf.green{background:var(--green)}.bf.amber{background:#C9850A}.bf.coral{background:#D85A30}
.bv{font-size:11px;color:var(--tmu);width:64px;text-align:right;font-weight:500;flex-shrink:0}

.stat-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:6px}
.sc{border:1px solid var(--bdr);border-radius:8px;padding:8px 4px;text-align:center;cursor:pointer;transition:transform .15s}
.sc:hover{transform:scale(1.05)}
.sc.ok{border-color:rgba(15,110,86,.3);background:rgba(15,110,86,.04)}
.sc.miss{border-color:var(--gold4);background:var(--gold3)}
.sc.fut{background:var(--off)}
.smo{font-size:10px;color:var(--tmu);margin-bottom:4px}
.slb{font-size:10px;font-weight:500}
.ok .slb{color:var(--green)}.miss .slb{color:var(--gold)}.fut .slb{color:var(--tmu)}

/* CAPACITY */
.cap-card{background:var(--white);border:1px solid var(--bdr);border-radius:12px;padding:18px 20px;margin-bottom:14px;position:relative;overflow:hidden}
.cap-card::before{content:'';position:absolute;top:0;left:0;bottom:0;width:4px;border-radius:2px}
.cap-card.hq::before{background:var(--navy)}
.cap-card.mdc::before{background:var(--blue)}
.cap-card.tks::before{background:#C9850A}
.cap-card.bangpu::before{background:#D85A30}
.cap-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;padding-left:12px}
.cap-name{font-size:14px;font-weight:500}
.cap-sub{font-size:10px;color:var(--tmu);margin-top:2px}
.cap-bdgs{display:flex;gap:6px;flex-wrap:wrap}
.cap-bdg{font-size:12px;font-weight:500;padding:4px 12px;border-radius:6px}
.prog-wrap{padding-left:12px;margin-bottom:12px}
.prog-row{margin-bottom:10px}
.prog-lbl{display:flex;justify-content:space-between;font-size:11px;color:var(--tmu);margin-bottom:5px}
.prog-name{font-weight:500;color:var(--tm)}
.prog-track{height:10px;background:var(--surf);border-radius:5px;overflow:hidden}
.prog-fill{height:100%;border-radius:5px;transition:width .5s ease}
.p-ok{background:var(--green)}.p-warn{background:#C9850A}.p-danger{background:var(--red)}
.floor-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:14px;padding-left:12px}
.floor-cell{background:var(--off);border:1px solid var(--bdr);border-radius:8px;padding:10px 8px;text-align:center}
.floor-name{font-size:9px;color:var(--tmu);margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.floor-val{font-size:14px;font-weight:500;font-family:'Playfair Display',serif}
.floor-cap{font-size:9px;color:var(--tmu);margin-top:1px}
.floor-bar-t{height:4px;border-radius:2px;background:var(--bdr);margin-top:5px;overflow:hidden}
.floor-bar-f{height:100%;border-radius:2px}
.cap-form{padding-left:12px;border-top:1px solid var(--bdr);padding-top:14px;margin-top:6px}
.cap-form-t{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);font-weight:500;margin-bottom:10px;display:flex;align-items:center;gap:6px}
.cap-form-t i{font-size:13px}

/* ALERTS */
.alert-c{border:1px solid var(--bdr);border-left:3px solid var(--gold2);border-radius:0 12px 12px 0;padding:14px 16px;margin-bottom:10px;display:flex;align-items:flex-start;gap:12px}
.alert-c:hover{border-color:var(--bdr2);border-left-color:var(--gold)}
.a-ico{width:34px;height:34px;background:var(--gold3);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.a-ico i{color:var(--gold);font-size:17px}
.a-title{font-size:13px;font-weight:500;color:var(--navy);margin-bottom:3px}
.a-desc{font-size:11px;color:var(--tmu);line-height:1.6}
.a-btn{margin-left:auto;flex-shrink:0;padding:7px 14px;background:var(--navy);border:none;border-radius:8px;color:var(--white);font-size:11px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif}
.a-btn:hover{background:var(--navy2)}

/* ANALYSIS */
.an-nav{display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap}
.an-t{padding:6px 14px;border:1px solid var(--bdr2);border-radius:20px;font-size:11px;font-weight:500;color:var(--tm);cursor:pointer;background:var(--white);font-family:'DM Sans',sans-serif;display:inline-flex;align-items:center;gap:5px;transition:all .15s}
.an-t.active{background:var(--navy);color:var(--white);border-color:var(--navy)}
.an-t:hover:not(.active){border-color:var(--navy);color:var(--navy)}
.an-t i{font-size:13px}
.an-sec{display:none}.an-sec.active{display:block}
.met4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin-bottom:16px}
.met{background:var(--off);border-radius:10px;padding:14px 16px;border:1px solid var(--bdr)}
.met-lbl{font-size:10px;color:var(--tmu);margin-bottom:5px;letter-spacing:.04em}
.met-val{font-family:'Playfair Display',serif;font-size:20px;color:var(--navy);line-height:1.1}
.met-sub{font-size:10px;color:var(--tmu);margin-top:4px}
.ib{background:var(--navy);border-radius:12px;padding:18px 20px;margin-bottom:16px}
.ib-title{font-size:11px;letter-spacing:.07em;text-transform:uppercase;color:var(--gold2);margin-bottom:12px;display:flex;align-items:center;gap:7px}
.ib-title i{font-size:14px}
.ib-row{display:flex;align-items:flex-start;gap:8px;margin-bottom:8px}
.ib-dot{width:5px;height:5px;border-radius:50%;background:var(--gold2);margin-top:6px;flex-shrink:0}
.ib-text{font-size:12px;color:rgba(255,255,255,.78);line-height:1.6}
.ib-text strong{color:var(--gold2)}

/* FORM */
.fg{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.fg3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.fg4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.fg5{display:grid;grid-template-columns:repeat(5,1fr);gap:10px}
.fgrp{margin-bottom:10px}
.fgrp label{display:block;font-size:10px;letter-spacing:.07em;text-transform:uppercase;color:var(--tmu);margin-bottom:5px;font-weight:500}
.fgrp input,.fgrp select{width:100%;padding:9px 12px;background:var(--white);border:1px solid var(--bdr2);border-radius:8px;color:var(--td);font-family:'DM Sans',sans-serif;font-size:13px;outline:none;transition:border-color .15s}
.fgrp input:focus,.fgrp select:focus{border-color:var(--gold2);box-shadow:0 0 0 3px rgba(212,168,67,0.09)}
.fgrp input::placeholder{color:#AEBDD0}
.fsec{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);font-weight:500;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--gold4);display:flex;align-items:center;gap:6px}
.fsec i{font-size:13px}
.btn-g{padding:9px 18px;background:var(--gold2);border:none;border-radius:8px;color:var(--white);font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:background .15s}
.btn-g:hover{background:var(--gold)}
.btn-n{padding:9px 18px;background:var(--navy);border:none;border-radius:8px;color:var(--white);font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:background .15s}
.btn-n:hover{background:var(--navy2)}
.btn-o{padding:9px 18px;background:transparent;border:1px solid var(--bdr2);border-radius:8px;color:var(--tm);font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:all .15s}
.btn-o:hover{border-color:var(--navy);color:var(--navy)}
.save-ok{background:var(--green2);border:1px solid rgba(15,110,86,.25);border-radius:9px;padding:10px 14px;font-size:12px;color:var(--green);margin-bottom:14px;display:none;align-items:center;gap:8px}
.info-box{background:var(--gold3);border:1px solid var(--gold4);border-left:3px solid var(--gold2);border-radius:0 8px 8px 0;padding:12px 14px;font-size:12px;color:var(--gold);line-height:1.6;margin-bottom:14px}
.legend-row{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--tmu)}
.legend-dot{width:10px;height:10px;border-radius:2px;flex-shrink:0}

table{width:100%;border-collapse:collapse;font-size:12px}
th{text-align:left;padding:9px 12px;font-size:10px;letter-spacing:.07em;text-transform:uppercase;color:var(--tmu);font-weight:500;border-bottom:2px solid var(--bdr);background:var(--off)}
td{padding:10px 12px;border-bottom:1px solid var(--bdr);color:var(--td)}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--off)}
.bdg-ok{background:var(--green2);color:var(--green);padding:2px 9px;border-radius:5px;font-size:10px;font-weight:500}
.bdg-ms{background:var(--gold3);color:var(--gold);padding:2px 9px;border-radius:5px;font-size:10px;font-weight:500}
.bdg-ft{background:var(--surf);color:var(--tmu);padding:2px 9px;border-radius:5px;font-size:10px}
.bdg-warn{background:var(--amber2);color:var(--amber);padding:2px 9px;border-radius:5px;font-size:10px;font-weight:500}
.bdg-danger{background:var(--red2);color:var(--red);padding:2px 9px;border-radius:5px;font-size:10px;font-weight:500}
.code-block{background:var(--navy);color:rgba(255,255,255,.82);padding:16px;border-radius:10px;font-size:10.5px;line-height:1.75;overflow-x:auto;font-family:monospace;white-space:pre;border:1px solid rgba(255,255,255,.06)}
.footer{background:var(--navy);border-radius:0 0 14px 14px;padding:14px 28px;display:flex;justify-content:space-between;align-items:center}
.fl{font-size:10px;color:rgba(255,255,255,.28);letter-spacing:.1em;text-transform:uppercase}
.fr{font-family:'Playfair Display',serif;font-size:14px;color:var(--gold2);letter-spacing:.06em}

@keyframes fadeIn{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}
.save-ok{animation:fadeIn .3s ease}
@media(max-width:960px){.kpi5,.kpi4{grid-template-columns:repeat(2,1fr)}.g2,.g3{grid-template-columns:1fr}.met4{grid-template-columns:1fr 1fr}.floor-grid{grid-template-columns:repeat(3,1fr)}.stat-grid{grid-template-columns:repeat(4,1fr)}.fg,.fg3,.fg4,.fg5{grid-template-columns:1fr 1fr}.shell{padding:10px}.topbar{padding:0 16px;border-radius:10px 10px 0 0}.nav{padding:0 14px}.body{padding:16px}.wh-chips{display:none}}
@media(max-width:580px){.kpi5,.kpi4{grid-template-columns:1fr 1fr}.met4{grid-template-columns:1fr}.floor-grid{grid-template-columns:1fr 1fr}.fg,.fg3,.fg4,.fg5{grid-template-columns:1fr}.stat-grid{grid-template-columns:repeat(3,1fr)}}
</style>
</head>
<body>
<div class="shell">

<div class="topbar">
  <div class="brand">
    <div class="brand-ico"><i class="ti ti-truck-delivery"></i></div>
    <div>
      <div class="brand-name">SYNNEX <span>Logistics</span></div>
      <div class="brand-sub">5-Warehouse Intelligence Platform</div>
    </div>
  </div>
  <div class="top-r">
    <div class="wh-chips" id="wh-chips"></div>
    <div class="top-chip live"><i class="ti ti-circle-filled" style="font-size:7px"></i> Live</div>
    <div class="top-chip" id="hdr-mo"></div>
  </div>
</div>
<div class="gold-bar"></div>

<div class="nav">
  <button class="nb active" onclick="sw('dashboard',this)"><i class="ti ti-layout-dashboard"></i> Dashboard</button>
  <button class="nb" onclick="sw('capacity',this)"><i class="ti ti-building-warehouse"></i> Capacity <span class="nb-cnt" id="cap-cnt"></span></button>
  <button class="nb" onclick="sw('analysis',this)"><i class="ti ti-chart-dots-3"></i> วิเคราะห์</button>
  <button class="nb" onclick="sw('alerts',this)"><i class="ti ti-bell"></i> แจ้งเตือน <span class="nb-cnt" id="a-cnt"></span></button>
  <button class="nb" onclick="sw('entry',this)"><i class="ti ti-edit"></i> กรอกข้อมูล</button>
  <button class="nb" onclick="sw('history',this)"><i class="ti ti-table"></i> ประวัติ</button>
  <button class="nb" onclick="sw('settings',this)"><i class="ti ti-settings"></i> ตั้งค่า</button>
</div>

<div class="body">

<!-- DASHBOARD -->
<div id="s-dashboard" class="sec active">
  <div class="kpi5" id="kpi-wh"></div>
  <div class="kpi4" id="kpi-main"></div>
  <div class="panel" style="margin-bottom:16px">
    <div class="ph">
      <div class="pt"><i class="ti ti-building-warehouse"></i> Pallet &amp; Tote Capacity — ภาพรวมทุกคลัง</div>
      <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap">
        <div class="legend-row"><div class="legend-dot" style="background:var(--green)"></div>&lt;80% ปกติ</div>
        <div class="legend-row"><div class="legend-dot" style="background:#C9850A"></div>80–95% เฝ้าระวัง</div>
        <div class="legend-row"><div class="legend-dot" style="background:var(--red)"></div>&gt;95% วิกฤต</div>
      </div>
    </div>
    <div id="dash-cap-bars"></div>
  </div>
  <div class="g2">
    <div class="panel">
      <div class="ph"><div class="pt"><i class="ti ti-chart-bar"></i> Revenue แยกคลัง</div><div class="ptag">ล้านบาท</div></div>
      <div id="ch-rev"></div>
    </div>
    <div class="panel">
      <div class="ph"><div class="pt"><i class="ti ti-calendar-stats"></i> สถานะข้อมูลรายเดือน Y2026</div></div>
      <div class="stat-grid" id="st-grid"></div>
    </div>
  </div>
  <div class="g2">
    <div class="panel">
      <div class="ph"><div class="pt"><i class="ti ti-trending-up"></i> Revenue เทรนด์ล่าสุด</div><div class="ptag" id="trend-tag"></div></div>
      <div id="ch-trend"></div>
    </div>
    <div class="panel">
      <div class="ph"><div class="pt"><i class="ti ti-truck"></i> ค่าขนส่ง BKK vs UPC</div><div class="ptag">ล้านบาท</div></div>
      <div id="ch-del"></div>
    </div>
  </div>
</div>

<!-- CAPACITY -->
<div id="s-capacity" class="sec">
  <div class="save-ok" id="cap-ok"><i class="ti ti-circle-check"></i> บันทึก Capacity สำเร็จ!</div>

  <div class="cap-card hq">
    <div class="cap-hdr">
      <div>
        <div class="cap-name" style="color:var(--navy)"><i class="ti ti-building-warehouse" style="color:var(--navy)"></i> HQ Warehouse (Synnex)</div>
        <div class="cap-sub">Bangna KM 7 · Pallet + Robot ASRS + Tote System</div>
      </div>
      <div class="cap-bdgs">
        <div class="cap-bdg" id="hq-pb">Pallet –</div>
        <div class="cap-bdg" id="hq-tb">Tote –</div>
      </div>
