  if(tab==='storage'){
    const avgPct=mos.length?mos.reduce((a,m)=>{const inv=(yrd[m].inv||1)*1e6;return a+((yrd[m].stor||0)/inv*100);},0)/mos.length:0;
    el.innerHTML=`<div class="met4">${[{lbl:'Storage avg./เดือน',val:N(aS/1e6)+' MB',sub:'Y2025'},{lbl:'% of Inventory',val:avgPct.toFixed(3)+'%',sub:'ค่าฝาก/มูลค่าคลัง'},{lbl:'Storage / Order',val:N(aS/Math.max(aO,1),0)+' บ.',sub:'ต้นทุนฝากต่อ Order'},{lbl:'Inventory avg.',val:N(avg(d=>d.inv))+' MB',sub:'/เดือน'}].map(m=>`<div class="met"><div class="met-lbl">${m.lbl}</div><div class="met-val">${m.val}</div><div class="met-sub">${m.sub}</div></div>`).join('')}</div><div class="g2"><div class="panel"><div class="ph"><div class="pt"><i class="ti ti-trending-up"></i> Storage เทรนด์ Y2025</div><div class="ptag">MB</div></div>${mos.map(m=>barRow(MO[m],(yrd[m].stor||0)/1e6,aS/1e6||1,'amber',' MB')).join('')}</div><div class="panel"><div class="ph"><div class="pt"><i class="ti ti-percentage"></i> Storage/Inventory รายเดือน</div></div>${mos.map(m=>{const p=(yrd[m].stor||0)/((yrd[m].inv||1)*1e6)*100;return barRow(MO[m],+p.toFixed(3),avgPct*2||1,'',' %');}).join('')}</div></div>`;
  }
  if(tab==='pickpack'){
    const ppO=aO>0?aPP/aO:0,ppD=aWD>0?aO/aWD:0,mxO=Math.max(...mos.map(m=>yrd[m].ord||0))||1,mxPO=Math.max(...mos.map(m=>yrd[m].ord>0?(yrd[m].pp||0)/yrd[m].ord:0))||1;
    el.innerHTML=`<div class="met4">${[{lbl:'Pick-Pack avg./เดือน',val:N(aPP/1e6)+' MB',sub:'Y2025'},{lbl:'บาท / Order',val:N(ppO,0)+' บ.',sub:'ต้นทุน PP/Order'},{lbl:'Orders / วันทำงาน',val:N(ppD,0),sub:'Productivity'},{lbl:'Orders avg.',val:N(aO,0),sub:'/เดือน'}].map(m=>`<div class="met"><div class="met-lbl">${m.lbl}</div><div class="met-val">${m.val}</div><div class="met-sub">${m.sub}</div></div>`).join('')}</div><div class="g2"><div class="panel"><div class="ph"><div class="pt"><i class="ti ti-package"></i> Orders เทรนด์ Y2025</div></div>${mos.map(m=>barRow(MO[m],yrd[m].ord||0,mxO,'')).join('')}</div><div class="panel"><div class="ph"><div class="pt"><i class="ti ti-coin"></i> บาท/Order รายเดือน</div></div>${mos.map(m=>{const v=yrd[m].ord>0?(yrd[m].pp||0)/yrd[m].ord:0;return barRow(MO[m],+v.toFixed(0),mxPO,'green',' บ.');}).join('')}</div></div>`;
  }
  if(tab==='sales'){
    const rpO=aO>0?aRev*1e6/aO:0,mxR=Math.max(...mos.map(m=>yrd[m].rev||0))||1;
    el.innerHTML=`<div class="met4">${[{lbl:'Revenue avg./เดือน',val:N(aRev)+' MB',sub:'Y2025'},{lbl:'บาท / Order',val:N(rpO,0)+' บ.',sub:'Revenue/Order'},{lbl:'Orders avg.',val:N(aO,0),sub:'/เดือน'},{lbl:'Revenue/Working Day',val:N(aWD>0?aRev/aWD:0)+' MB',sub:'Productivity'}].map(m=>`<div class="met"><div class="met-lbl">${m.lbl}</div><div class="met-val">${m.val}</div><div class="met-sub">${m.sub}</div></div>`).join('')}</div><div class="g2"><div class="panel"><div class="ph"><div class="pt"><i class="ti ti-trending-up"></i> Revenue เทรนด์ Y2025</div><div class="ptag">MB</div></div>${mos.map(m=>barRow(MO[m],yrd[m].rev||0,mxR,'',' MB')).join('')}</div><div class="panel"><div class="ph"><div class="pt"><i class="ti ti-coin"></i> บาท/Order (Revenue)</div></div>${mos.map(m=>{const v=yrd[m].ord>0?(yrd[m].rev||0)*1e6/yrd[m].ord:0;return barRow(MO[m],+v.toFixed(0),Math.max(...mos.map(x=>yrd[x].ord>0?(yrd[x].rev||0)*1e6/yrd[x].ord:0))||1,'navy',' บ.');}).join('')}</div></div>`;
  }
  if(tab==='compare'){
    const rows=WH_KEYS.map((k,i)=>{const sr=aRev*WH_PCT[i]/100,sc=aC*WH_PCT[i]/100/1e6,ss=aS*WH_PCT[i]/100,sp=aPP*WH_PCT[i]/100,so=aO*WH_PCT[i]/100,ppo=so>0?sp/so:0,cp=sr>0?sc/sr*100:0;return {k,i,sr,sc,ss,so,ppo,cp};});
    el.innerHTML=`<div class="ib"><div class="ib-title"><i class="ti ti-arrows-diff"></i> เปรียบเทียบ 5 คลัง</div>${rows.map(r=>`<div class="ib-row"><div class="ib-dot" style="background:${WH_COLS[r.i]}"></div><div class="ib-text"><strong style="color:${WH_COLS[r.i]}">${WH_LBL[r.i]}</strong>: Revenue ${N(r.sr)} MB · ขนส่ง ${N(r.sc)} MB · Storage ${N(r.ss,0)} บ. · PP ${N(r.ppo,0)} บ./Order</div></div>`).join('')}</div><div class="panel" style="padding:0;overflow:hidden"><div style="overflow-x:auto"><table><thead><tr><th>คลัง</th><th style="color:var(--gold2)">Revenue (MB)</th><th>ค่าขนส่ง (MB)</th><th>Storage (บ.)</th><th>PP บ./Order</th><th>% ต้นทุน/Rev</th></tr></thead><tbody>${rows.map(r=>`<tr><td style="font-weight:500;color:${WH_COLS[r.i]}">${WH_LBL[r.i]}</td><td>${N(r.sr)}</td><td>${N(r.sc)}</td><td>${N(r.ss,0)}</td><td>${N(r.ppo,0)}</td><td>${r.cp.toFixed(2)}%</td></tr>`).join('')}<tr><td><strong>รวม</strong></td><td>${N(aRev)}</td><td>${N(aC/1e6)}</td><td>${N(aS,0)}</td><td>${N(aO>0?aPP/aO:0,0)}</td><td>${(aC/1e6/aRev*100).toFixed(2)}%</td></tr></tbody></table></div></div>`;
  }
  if(tab==='caputilize'){
    const cMs=Object.keys(CAP[CY]||{}).map(Number).sort();
    const series=[{lbl:'HQ Pallet',fn:d=>d.hqPC>0?(d.hqPU||0)/d.hqPC*100:null,col:WH_COLS[0]},{lbl:'HQ Tote',fn:d=>d.hqTC>0?(d.hqTU||0)/d.hqTC*100:null,col:'#185FA5'},{lbl:'MDC',fn:d=>d.mdcPC>0?(d.mdcPU||0)/d.mdcPC*100:null,col:WH_COLS[1]},{lbl:'TKS',fn:d=>d.tksPC>0?(d.tksPU||0)/d.tksPC*100:null,col:WH_COLS[2]},{lbl:'บางปู',fn:d=>d.bpPC>0?(d.bpPU||0)/d.bpPC*100:null,col:WH_COLS[3]}];
    const sums=series.map(s=>{const vals=cMs.map(m=>{const d=getCD(CY,m);return s.fn(d)||0;});return {...s,avg:vals.length?vals.reduce((a,b)=>a+b,0)/vals.length:0,max:Math.max(...vals,0)};});
    el.innerHTML=`<div class="ib"><div class="ib-title"><i class="ti ti-chart-area"></i> Capacity Utilization Y${CY}</div>${sums.map(s=>`<div class="ib-row"><div class="ib-dot" style="background:${pCol(s.avg/100)}"></div><div class="ib-text"><strong style="color:${pCol(s.avg/100)}">${s.lbl}</strong>: เฉลี่ย <strong style="color:${pCol(s.avg/100)}">${s.avg.toFixed(1)}%</strong> · สูงสุด ${s.max.toFixed(1)}% · ${s.avg>=95?'⚠️ วิกฤต':s.avg>=80?'⚠️ เฝ้าระวัง':'✓ ปกติ'}</div></div>`).join('')}</div><div class="g2">${series.map(s=>`<div class="panel"><div class="ph"><div class="pt" style="color:${s.col}">${s.lbl}</div></div>${cMs.length?cMs.map(m=>{const d=getCD(CY,m);const v=s.fn(d)||0;return `<div class="br"><div class="bl">${MO[m]}</div><div class="bt"><div class="prog-fill ${pCls(v/100)}" style="height:100%;width:${Math.min(100,v).toFixed(1)}%;border-radius:4px"></div></div><div class="bv" style="color:${pCol(v/100)}">${v.toFixed(1)}%</div></div>`;}).join(''):'<div style="color:var(--tmu);font-size:12px;padding:8px">ยังไม่มีข้อมูล</div>'}</div>`).join('')}</div>`;
  }
}

function sw(t,el){
  document.querySelectorAll('.sec').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.nb').forEach(x=>x.classList.remove('active'));
  document.getElementById('s-'+t).classList.add('active');
  el.classList.add('active');
  if(t==='history')rHist();
  if(t==='analysis'){const at=document.querySelector('.an-t.active');swAn(at?at.textContent.trim().includes('ต้นทุน')?'cost':at.getAttribute('onclick').match(/swAn\('(\w+)'/)?.[1]||'cost':'cost',at||document.querySelector('.an-t'));}
  if(t==='capacity'){rCap();loadCap();}
  if(t==='settings'&&CFG.gsUrl)document.getElementById('gs-url').value=CFG.gsUrl;
}

function swAn(tab,el){
  document.querySelectorAll('.an-sec').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.an-t').forEach(x=>x.classList.remove('active'));
  document.getElementById('an-'+tab).classList.add('active');
  if(el)el.classList.add('active');
  rAn(tab);
}

function goFill(yr,mo){
  document.getElementById('e-yr').value=yr;document.getElementById('e-mo').value=mo;
  document.querySelectorAll('.sec').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.nb').forEach(x=>x.classList.remove('active'));
  document.getElementById('s-entry').classList.add('active');
  document.querySelectorAll('.nb')[4].classList.add('active');
}

function saveFrm(){
  const yr=parseInt(document.getElementById('e-yr').value),mo=parseInt(document.getElementById('e-mo').value);
  const g=(id)=>parseFloat(document.getElementById(id).value)||null;
  const row={rev:g('e-rev'),inv:g('e-inv'),wd:g('e-wd'),coa:g('e-coa'),ord:g('e-ord'),itm:g('e-itm'),cbkk:g('e-cbkk'),cupc:g('e-cupc'),dbkk:g('e-dbkk'),dupc:g('e-dupc'),stor:g('e-stor'),pp:g('e-pp'),wh:document.getElementById('e-wh').value};
  if(!DB[yr])DB[yr]={};DB[yr][mo]=Object.assign(DB[yr][mo]||{},row);
  localStorage.setItem('lg6_db',JSON.stringify(DB));
  const ok=document.getElementById('save-ok');ok.style.display='flex';setTimeout(()=>ok.style.display='none',3000);
  if(CFG.gsUrl)fetch(CFG.gsUrl,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({type:'logistics',yr,mo,...row})}).catch(()=>{});
  rKPI();rRevChart();rDelChart();rTrend();rStatus();rAlerts();
}

function clrFrm(){['e-rev','e-inv','e-wd','e-coa','e-ord','e-itm','e-cbkk','e-cupc','e-dbkk','e-dupc','e-stor','e-pp'].forEach(id=>document.getElementById(id).value='');}
function saveCfg(){CFG.gsUrl=document.getElementById('gs-url').value;localStorage.setItem('lg6_cfg',JSON.stringify(CFG));document.getElementById('cfg-msg').innerHTML='<span style="color:var(--green)"><i class="ti ti-check"></i> บันทึกแล้ว</span>';}
function testCfg(){const u=document.getElementById('gs-url').value;if(!u)return;document.getElementById('cfg-msg').textContent='กำลังทดสอบ...';fetch(u).then(r=>r.json()).then(()=>document.getElementById('cfg-msg').innerHTML='<span style="color:var(--green)"><i class="ti ti-circle-check"></i> เชื่อมต่อสำเร็จ!</span>').catch(()=>document.getElementById('cfg-msg').innerHTML='<span style="color:var(--red)"><i class="ti ti-x"></i> เชื่อมต่อไม่ได้</span>');}
function cpSc(){navigator.clipboard.writeText(document.getElementById('sc-pre').textContent).then(()=>{const b=event.target.closest('button');b.innerHTML='<i class="ti ti-check"></i> คัดลอกแล้ว';setTimeout(()=>b.innerHTML='<i class="ti ti-copy"></i> คัดลอกสคริปต์',2000);});}
function exportData(){const blob=new Blob([JSON.stringify({logistics:DB,capacity:CAP},null,2)],{type:'application/json'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=`synnex_logistics_${new Date().toISOString().slice(0,10)}.json`;a.click();}

rKPI();rRevChart();rDelChart();rTrend();rStatus();rAlerts();rCap();
</script>
</body>
</html>
